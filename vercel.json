{
  "version": 2,
  "name": "nyris-portal",
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/requests/crop/:requestId",
      "destination": "/requests-crop.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
